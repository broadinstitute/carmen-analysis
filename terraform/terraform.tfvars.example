# Copy to terraform.tfvars and fill in. terraform.tfvars is gitignored.

# REQUIRED.
# Email shown on the IAP OAuth consent screen. Use a group address you control,
# not a personal email.
iap_support_email = "carmen-eng@broadinstitute.org"

# REQUIRED for anyone to actually log in once IAP is in front of the app.
# Add Google Groups (preferred) or individual user accounts.
iap_members = [
  "group:sabeti-lab@broadinstitute.org",
  # "user:dpark@broadinstitute.org",
]

# Optional overrides — defaults in variables.tf are appropriate for production.
# project_id              = "sabeti-adapt"
# region                  = "us-central1"
# domain                  = "carmen-analysis.broadinstitute.org"
# image                   = "us-central1-docker.pkg.dev/sabeti-adapt/carmen-analysis/carmen-analysis:latest"

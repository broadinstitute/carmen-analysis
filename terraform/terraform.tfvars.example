# Copy to terraform.tfvars and fill in only what you need to override.
# terraform.tfvars is gitignored.
#
# All variables currently have suitable defaults in variables.tf — the file can
# be empty for the standard sabeti-adapt deployment. Override per-environment
# values here as needed:
#
# project_id              = "sabeti-adapt"
# region                  = "us-central1"
# domain                  = "carmen-analysis.broadinstitute.org"
# image                   = "us-central1-docker.pkg.dev/sabeti-adapt/carmen-analysis/carmen-analysis:latest"
# cloud_run_min_instances = 0
# cloud_run_max_instances = 5
# cloud_run_cpu           = "2"
# cloud_run_memory        = "2Gi"
